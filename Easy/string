/**
 * LeetCode 14. Longest Common Prefix
 *
 * Problem: Write a function to find the longest common prefix string amongst an array of strings.
 * If there is no common prefix, return an empty string "".
 *
 * Key Logic: Take first string as prefix.
 * Compare with every other string and keep reducing prefix until it matches.
 *
 * Time Complexity: O(S) where S = sum of all characters in all strings
 * Space Complexity: O(1)
 *
 * Runtime: 1ms | Beats 95.2%
 * Memory: 42.1MB | Beats 97.6%
 *
 * Date: 04-04-2026
 * Author: Mah
 */

class Solution {
    public String longestCommonPrefix(String[] strs) {

        if(strs == null || strs.length == 0) return "";

        String prefix = strs[0];

        for(int i = 1; i < strs.length; i++) {

            while(strs[i].indexOf(prefix)!= 0) {
                prefix = prefix.substring(0, prefix.length() - 1);

                if(prefix.isEmpty()) return "";
            }
        }
        return prefix;
    }
}